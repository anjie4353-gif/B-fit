GROQ_API_KEY=your_groq_api_key_here

# Public HTTPS URL — required for phone install & APK (share this link with users)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Server database driver: sqlite (default) | redis | file
# Wellness sync + server progress APIs require sqlite
BFIT_DB_DRIVER=sqlite

# Optional: server backup for multi-device (Upstash Redis on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy WhatsApp API (not required for PWA mode)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

CRON_SECRET=your_random_secret_here